MODULE main
VAR
	state_ : {s0, s1, s2, s3, s4, s5, s6, s7, s8, s9, s10, s11, s12, s_done, s_abort};
	ACK_ambiguous : boolean;
	Connection_aborted : boolean;
	Karn_idle : boolean;
	Karn_sampled : boolean;
	Karn_tracking : boolean;
	RTO_first_sample : boolean;
	RTO_steady_state : boolean;
	RTO_updating : boolean;
	Retransmission_active : boolean;
	Transmission_complete : boolean;
	fresh_sample : boolean;
	rto_adequate : boolean;
	rto_initialized : boolean;
	sampling_blocked : boolean;
	sampling_enabled : boolean;
	spurious_timeout : boolean;
	srtt_converging : boolean;
	timeout_risk : boolean;
	transmission_active : boolean;

-- Fairness: бесконечная ретрансмиссия без исхода нереалистична
FAIRNESS
	sampling_enabled | Transmission_complete | Connection_aborted

ASSIGN
	init(state_) := s0;
	next(state_) := case
		(state_ = s0) : {s1};
		(state_ = s1) : {s2, s3};
		(state_ = s2) : {s3, s6};
		(state_ = s3) : {s4};
		(state_ = s4) : {s3, s5, s_abort};
		(state_ = s5) : {s1};
		(state_ = s6) : {s7, s8};
		(state_ = s7) : {s8};
		(state_ = s8) : {s9};
		(state_ = s9) : {s10, s11};
		(state_ = s10) : {s1, s_done};
		(state_ = s11) : {s12};
		(state_ = s12) : {s3};
		(state_ = s_done) : {s_done};
		(state_ = s_abort) : {s_abort};
		TRUE: state_;
	esac;

-- Predicate definitions
	ACK_ambiguous :=
		case
			(state_ = s5) : TRUE;
			TRUE : FALSE;
		esac;
	Connection_aborted :=
		case
			(state_ = s_abort) : TRUE;
			TRUE : FALSE;
		esac;
	Karn_idle :=
		case
			(state_ = s0) : TRUE;
			TRUE : FALSE;
		esac;
	Karn_sampled :=
		case
			(state_ = s6) : TRUE;
			TRUE : FALSE;
		esac;
	Karn_tracking :=
		case
			(state_ = s1) | (state_ = s2) : TRUE;
			TRUE : FALSE;
		esac;
	RTO_first_sample :=
		case
			(state_ = s7) : TRUE;
			TRUE : FALSE;
		esac;
	RTO_steady_state :=
		case
			(state_ = s9) : TRUE;
			TRUE : FALSE;
		esac;
	RTO_updating :=
		case
			(state_ = s8) : TRUE;
			TRUE : FALSE;
		esac;
	Retransmission_active :=
		case
			(state_ = s3) : TRUE;
			TRUE : FALSE;
		esac;
	Transmission_complete :=
		case
			(state_ = s_done) : TRUE;
			TRUE : FALSE;
		esac;
	fresh_sample :=
		case
			(state_ = s6) : TRUE;
			TRUE : FALSE;
		esac;
	rto_adequate :=
		case
			(state_ = s10) : TRUE;
			TRUE : FALSE;
		esac;
	rto_initialized :=
		case
			(state_ = s7) | (state_ = s8) | (state_ = s9) | (state_ = s10) | (state_ = s11) : TRUE;
			TRUE : FALSE;
		esac;
	sampling_blocked :=
		case
			(state_ = s3) | (state_ = s4) | (state_ = s5) | (state_ = s12) | (state_ = s_abort) : TRUE;
			TRUE : FALSE;
		esac;
	sampling_enabled :=
		case
			(state_ = s2) : TRUE;
			TRUE : FALSE;
		esac;
	spurious_timeout :=
		case
			(state_ = s12) : TRUE;
			TRUE : FALSE;
		esac;
	srtt_converging :=
		case
			(state_ = s9) | (state_ = s10) | (state_ = s11) : TRUE;
			TRUE : FALSE;
		esac;
	timeout_risk :=
		case
			(state_ = s11) : TRUE;
			TRUE : FALSE;
		esac;
	transmission_active :=
		case
			(state_ = s1) | (state_ = s2) | (state_ = s3) | (state_ = s4) : TRUE;
			TRUE : FALSE;
		esac;

SPEC
	AG (EX TRUE)

SPEC
	AG !(sampling_enabled & sampling_blocked)

SPEC
	AG ((sampling_blocked & !Transmission_complete & !Connection_aborted) -> AF (sampling_enabled | Transmission_complete | Connection_aborted))

SPEC
	AG (fresh_sample -> AF rto_initialized)

SPEC
	AG (rto_initialized -> AF (rto_adequate | spurious_timeout))

SPEC
	AG !(rto_adequate & timeout_risk)

SPEC
	AG (spurious_timeout -> AF sampling_blocked)
